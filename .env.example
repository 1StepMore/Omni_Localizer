# Omni-Localizer Environment Variables
# Copy this file to .env and fill in your actual API keys

# ===== LLM Provider Keys =====
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

BAIDU_API_KEY=your_baidu_api_key_here
BAIDU_BASE_URL=https://qianfan.baidubce.com/v2

OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===== Logging Options (optional) =====
# OL_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
# OL_LOG_DIR=logs    # Log directory
# OL_LOG_CONSOLE=1  # Set to 1 to enable console output
