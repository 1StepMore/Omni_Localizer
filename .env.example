# Omni-Localizer Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your actual values, OR export them in
# your shell. DO NOT commit `.env` to source control (it is gitignored).
#
# Lookup precedence (highest first):
#   1. Real environment variable (shell export, CI secret, Docker -e, ...)
#   2. `.env` file (auto-loaded by ol_cli; override path via `OL_DOTENV`)
# ---------------------------------------------------------------------------

# ===== LLM Provider Keys =====
# These are resolved at runtime from YAML config via the `${VAR_NAME}` syntax
# in `config/default.yaml` (see `ol_pool/router.py::_resolve_env_vars`).
# At least one provider key MUST be set for real translations to work.

# Zhipu AI (glm-4-flash, primary translation model)
ZHIPU_API_KEY=<your-zhipu-api-key>

# Agnes AI (agnes-2.0-flash, primary judging model)
AGNES_API_KEY=<your-agnes-api-key>

# NVIDIA NIM (deepseek-ai/deepseek-v4-flash, free-tier fallback)
NVIDIA_NIM_API_KEY=<your-nvidia-nim-api-key>

# OpenCode Go (deepseek-v4-flash, lowest-priority backup)
OPENCODE_GO_KEY=<your-opencode-go-key>
OPENCODE_GO_BASE_URL=<your-opencode-go-base-url>


# ===== CLI Configuration Overrides =====
# These are read directly from `os.environ` by `src/ol_cli.py`.

# Path to YAML config. Default: `config/default.yaml`
# OL_CONFIG_PATH=config/default.yaml

# Path to an explicit `.env` file to load. When unset, ol_cli auto-discovers
# `.env` in the current working directory.
# OL_DOTENV=.env

# Cache directory for translation artifacts. Default: `~/.omni_cache`
# OMNI_CACHE_DIR=~/.omni_cache


# ===== Test / CI Toggles =====
# These switch between the in-process FAKE_LLM seam and a real provider call.
# See `tests/test_cli_smoke.py` and `tests/real_llm/conftest.py`.
#
# IMPORTANT (ULTRAREADY-VERIFY 2026-06-07): the FAKE_LLM seam is an opt-in
# test hook — NEVER set `OMNI_TEST_FAKE_LLM=1` in production. If you copy
# this file to `.env` for production deployment, leave both lines below
# commented out. Tests set the env var explicitly in their own subprocess
# env via `tests/test_cli_smoke.py` and `conftest.py`.

# Set to `1` to short-circuit LLM calls in tests with placeholder responses.
# Recommended for local dev + CI without provider credentials.
# POST_MORTEM OL-VERIFY: commented by default to prevent production leaks
# (the previous default of `=1` made the CLI use a fake ModelPool).
# OMNI_TEST_FAKE_LLM=1

# Set to `1` to ENABLE real-LLM test paths (requires a valid API key above).
# When unset, real-LLM tests are skipped automatically.
# OMNI_RUN_REAL_LLM=1


# ===== Logging (optional) =====
# OL_LOG_LEVEL=INFO         # DEBUG, INFO, WARNING, ERROR
# OL_LOG_DIR=logs           # Log output directory
# OL_LOG_CONSOLE=1          # Set to 1 to mirror logs to stderr


# ===== HuggingFace (advanced) =====
# Automatically toggled by `ol_md/repair/level2.py` and `ol_xliff/repair/level2.py`
# during offline HF Hub operations. You usually do NOT need to set this.
# HF_HUB_OFFLINE=0
