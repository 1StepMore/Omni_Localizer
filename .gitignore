# Per-user/per-machine config overrides (real values).
# `default.yaml` is tracked as a TEMPLATE — never put real keys/endpoints in it.
# Use `local.yaml` and pass `--config Omni_Localizer/config/local.yaml` to CLI.
config/local.yaml
config/local.*.yaml
config/secret.yaml
config/production.yaml
# Per-project book configs (added after May 2026 leak; these were the source
# of the C2 finding. Pattern matches book_localization.yaml and any
# future book_*.yaml that holds real LLM keys.)
config/book_localization.yaml
config/book_*.yaml
# Per-test local overrides (e.g., test_local.yaml with real keys for one-shot runs)
config/test_local.yaml
config/test_local.*.yaml
# Temp configs written by scripts/calibrate_m2.7.py to force a specific
# translation model in the ModelPool (one file per target model).
config/.calibration_*.yaml

# Local scripts (template versions tracked, secrets set via env vars)
test_en_to_zh.bat
test_zh_to_en.bat

# Agent/Sisyphus internal files
.sisyphus/
.omo/

# uv lock file (generated, not needed in repo)
uv.lock

# Output directory
output/
